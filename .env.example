# ══════════════════════════════════════════════════════════════════
# SxB VPN — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════════

# ── Base de données ───────────────────────────────────────────────
DATABASE_URL=postgresql://sxbvpn:sxbvpn_secret@localhost:5432/sxbvpn
POSTGRES_USER=sxbvpn
POSTGRES_PASSWORD=sxbvpn_secret
POSTGRES_DB=sxbvpn

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Chiffrement des configs VPN ──────────────────────────────────
# Exactement 32 caractères (AES-256)
ENCRYPTION_KEY=change_me_32_chars_minimum_here!!

# ── Token cryptographique ─────────────────────────────────────────
# Secret pour signer les tokens d'activation (min 32 caractères)
SERVER_SECRET=change_me_server_secret_minimum_32_chars!!
# Durée de validité des tokens en millisecondes (3600000 = 1 heure)
TOKEN_VALIDITY_MS=3600000

# ── Super Admin par défaut (seed) ───────────────────────────────
SEED_ADMIN=true
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_EMAIL=admin@sxbvpn.com
SEED_ADMIN_PASSWORD=Change_Me_Now!

# ── Backend ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://dashboard.sxbvpn.com,https://*.vercel.app
BCRYPT_ROUNDS=12

# ── Dashboard ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.sxbvpn.com/api
NEXTAUTH_SECRET=change_me
NEXTAUTH_URL=https://dashboard.sxbvpn.com
