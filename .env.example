# ─── Stuff The VPN — Variables d'environnement ───────────────────────────────
# Copier ce fichier vers .env et remplir les valeurs.

# Database
DATABASE_URL=postgresql://stv_user:stv_password@localhost:5432/stuff_the_vpn

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# Backend
PORT=3001
NODE_ENV=development

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@stuffthevpn.com
SMTP_PASS=your_smtp_password

# VPN Servers (Phase 6)
# V2RAY_API_URL=http://v2ray:8080
# SSH_API_URL=http://ssh-manager:8081
