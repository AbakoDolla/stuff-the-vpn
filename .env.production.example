# ════════════════════════════════════════════════════════════════
# SxB VPN — Variables de production
# cp .env.production.example .env
# ════════════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────────────
POSTGRES_DB=sxbvpn
POSTGRES_USER=stv_user
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT

# ── Backend JWT ──────────────────────────────────────────────────
# Générez avec: openssl rand -base64 48
JWT_SECRET=CHANGEZ_MOI_SECRET_JWT_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ── Admin par défaut ──────────────────────────────────────────────
SEED_ADMIN=true
ADMIN_EMAIL=admin@sxbvpn.com
ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_ADMIN
ADMIN_USERNAME=SxBVPN

# ── CORS ─────────────────────────────────────────────────────────
# Mettez l'URL de votre dashboard si connu, sinon * pour tout autoriser
CORS_ORIGIN=*
