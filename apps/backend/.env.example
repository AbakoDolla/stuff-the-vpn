# ===========================================
# SxB VPN Backend - Configuration
# ===========================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://sxbvpn:sxbvpn_secret@localhost:5432/sxbvpn

# Redis (rate limiting & sessions)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change_me_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated origins or * for all)
CORS_ORIGIN=http://localhost:3000

# Encryption key for sensitive data (min 32 chars)
ENCRYPTION_KEY=change_me_32_chars_minimum_here!!

# Admin auto-seed on first run
SEED_ADMIN=true
ADMIN_EMAIL=admin@sxbvpn.com
ADMIN_PASSWORD=SxBvpn2026!
ADMIN_USERNAME=SxBVPN

# Bcrypt rounds for password hashing (default: 12)
BCRYPT_ROUNDS=12

# V2Ray / Xray Stats API
# Enable real-time per-user traffic monitoring
# Requires StatsService + HTTP API enabled in your V2Ray/Xray config
V2RAY_API_URL=http://127.0.0.1:10085
V2RAY_API_ENABLED=false

# Traffic sync interval in milliseconds (default: 60 s)
TRAFFIC_SYNC_INTERVAL_MS=60000
