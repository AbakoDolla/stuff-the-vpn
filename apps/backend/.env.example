# ─── Backend environment variables ───────────────────────────────────────────
  NODE_ENV=development
  PORT=5000

  # Database (PostgreSQL)
  DATABASE_URL=postgresql://user:password@localhost:5432/sxbvpn

  # JWT
  JWT_SECRET=change_me_at_least_32_chars_long!!
  JWT_EXPIRES_IN=7d
  BCRYPT_ROUNDS=12

  # CORS
  CORS_ORIGIN=http://localhost:3000

  # Auto-create admin on startup (set to "true" in first run)
