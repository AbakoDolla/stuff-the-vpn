# ===========================================
# SxB VPN Backend - Production Configuration
# ===========================================

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL) - Use your production database URL
# Example: postgresql://user:password@db.provider.com:5432/database
DATABASE_URL=postgresql://user:password@db.example.com:5432/sxbvpn

# Redis (rate limiting & sessions) - Use your production Redis URL
# Example: redis://user:password@redis.provider.com:6379
REDIS_URL=redis://default:password@redis.example.com:6379

# JWT Authentication - Use strong secrets for production
JWT_SECRET=your_strong_jwt_secret_min_32_chars_here_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS - Restrict to your frontend domain(s) in production
# Can be a single URL or comma-separated list: https://app.example.com,https://www.example.com
CORS_ORIGIN=https://app.example.com

# Encryption key for sensitive data (min 32 chars, MUST be different from development)
ENCRYPTION_KEY=your_strong_encryption_key_32_chars_min_change_this

# Server secret for internal communications
SERVER_SECRET=your_strong_server_secret_32_chars_min_change_this

# Admin credentials (only used if SEED_ADMIN=true on first deployment)
SEED_ADMIN=false
ADMIN_EMAIL=admin@sxbvpn.com
ADMIN_PASSWORD=generate_strong_password_here
ADMIN_USERNAME=SxBVPN

# Bcrypt rounds for password hashing (12-14 for production)
BCRYPT_ROUNDS=12

# V2Ray / Xray Stats API (optional)
# V2RAY_API_URL=http://v2ray-service:10085
# V2RAY_API_ENABLED=false

# Traffic sync interval in milliseconds (default: 60 s)
TRAFFIC_SYNC_INTERVAL_MS=60000
