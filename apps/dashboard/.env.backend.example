# Backend API Configuration
# Copy this file to .env.local and update with your VPS backend details

# VPS Backend URL
# Example: https://vpn-backend.example.com
# Or: http://localhost:4000 (for local development)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend Admin Credentials (optional, for testing)
# BACKEND_ADMIN_EMAIL=admin@example.com
# BACKEND_ADMIN_PASSWORD=your_password_here
