// schema.prisma
// Schéma de la base de données — Stuff The VPN
//
// Entités prévues (Phase 2):
// - User         : Comptes utilisateurs (clients et revendeurs)
// - Reseller     : Profils des revendeurs
// - Voucher      : Codes d'accès VPN
// - Device       : Appareils des utilisateurs
// - Server       : Serveurs VPN (V2Ray, SSH)
// - Usage        : Suivi de consommation
// - Log          : Journal d'événements
// - Subscription : Abonnements et historique
//
// TODO (Phase 2): Définir tous les modèles et lancer la migration initiale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

