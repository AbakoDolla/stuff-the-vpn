# Mobile App Backend Configuration
# Copy this file to .env (if using flutter_dotenv) or update your build.gradle/xcode config

# VPS Backend API URL
# Example: https://vpn-backend.example.com/api
# Or: http://10.0.2.2:4000/api (Android emulator localhost)
# Or: http://localhost:4000/api (iOS simulator)
BACKEND_URL=http://localhost:4000/api

# Enable Crash Logging (optional)
ENABLE_CRASH_LOGGING=true

# Log Level (debug, info, warning, error)
LOG_LEVEL=info
