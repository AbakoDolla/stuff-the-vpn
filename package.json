{
  "name": "stuff-the-vpn",
  "version": "0.1.0",
  "private": true,
  "description": "Plateforme SaaS VPN commerciale — V2Ray & SSH",
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "lib/*"
  ],
  "scripts": {
    "dev": "echo 'Use docker-compose or run apps individually. See docs/deployment.md'",
    "lint": "pnpm exec eslint --workspace-root --ignore-path .gitignore .",
    "typecheck": "pnpm exec tsc -b .",
    "build": "pnpm run build:prisma && pnpm -r build",
    "build:prisma": "cd apps/backend && DATABASE_URL='postgresql://dummy:dummy@localhost:5432/dummy' pnpm prisma generate",
    "start:backend": "cd apps/backend && pnpm start",
    "start:dashboard": "cd apps/dashboard && pnpm start"
  },
  "devDependencies": {
    "typescript": "^5.1.3",
    "prettier": "^2.8.8",
    "eslint": "^8.42.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
